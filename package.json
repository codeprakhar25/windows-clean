{
  "name": "windows-clean",
  "version": "0.1.0",
  "private": true,
  "description": "Dry-run Windows space recovery assistant prototype with guarded cleanup workflows.",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite --host 127.0.0.1",
    "dev:tauri": "vite --host 127.0.0.1 --port 4173 --strictPort",
    "native:dev": "tauri dev",
    "native:build": "tauri build",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "demo:rehearsal": "node scripts/run-demo-rehearsal.mjs",
    "native:rehearsal": "node scripts/run-native-readonly-rehearsal.mjs",
    "openai:smoke": "node scripts/run-openai-advisor-smoke.mjs",
    "openai:smoke:fixture": "node scripts/run-openai-advisor-smoke.mjs --fixture-only",
    "setup:doctor": "node scripts/run-setup-doctor.mjs",
    "setup:route": "node scripts/run-setup-route.mjs",
    "validate:route": "node scripts/run-windows-validation-packet.mjs",
    "validate:route-contracts": "node scripts/run-route-contract-audit.mjs",
    "validate:first-route-preflight": "node scripts/run-first-route-preflight-check.mjs",
    "validate:first-route-completion": "node scripts/run-first-route-completion-check.mjs",
    "validate:workflow-proof": "node scripts/run-workflow-proof-check.mjs",
    "proof:first-route": "node scripts/run-first-route-proof.mjs",
    "proof:first-route:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-first-route-proof-windows.ps1",
    "proof:first-route:windows:finalize": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-first-route-proof-windows.ps1 -FinalizeOnly",
    "proof:route:windows": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-route-proof-windows.ps1",
    "proof:route:windows:finalize": "powershell -ExecutionPolicy Bypass -File .\\scripts\\run-route-proof-windows.ps1 -FinalizeOnly",
    "test": "node tests/guardrails.test.js && node tests/native-scanner.test.js && node tests/route-boundary-contracts.test.js && node tests/route-contract-audit.test.js && node tests/first-route-proof.test.js && node tests/first-route-windows-runner.test.js && node tests/route-windows-runner.test.js && node tests/first-route-preflight-check.test.js && node tests/first-route-completion-check.test.js && node tests/openai-agent.test.js && node tests/openai-smoke.test.js && node tests/setup-route.test.js && node tests/setup-doctor.test.js && node tests/windows-validation-packet.test.js && node tests/workflow-proof-check.test.js && node tests/demo-rehearsal.test.js && node tests/native-readonly-rehearsal.test.js && node tests/static-app.test.js",
    "check": "npm run build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  },
  "keywords": [
    "windows",
    "disk-cleanup",
    "space-recovery",
    "dry-run"
  ],
  "license": "UNLICENSED"
}
