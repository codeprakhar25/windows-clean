# Native Tauri OpenAI advisor. Browser-only demos may still use the legacy
# VITE_OPENAI_API_KEY and VITE_OPENAI_MODEL names, but the desktop app reads
# OPENAI_API_KEY from the native process or this local .env file.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_REASONING_EFFORT=low

# Native Tauri runtime only. Enables temp cleanup for old files under
# allowlisted Windows temp roots. Keep unset for read-only/demo builds.
SPACEGUARD_ENABLE_TEMP_EXECUTOR=0

# Native Tauri runtime only. Enables reviewed node_modules cleanup for selected
# project dependency targets with parent package.json evidence.
SPACEGUARD_ENABLE_PROJECT_DEPS_EXECUTOR=0

# Native Tauri runtime only. Enables reviewed old installer/archive files under
# the current user's Downloads folder to be moved through Recycle Bin semantics.
SPACEGUARD_ENABLE_DOWNLOADS_EXECUTOR=0

# Native Tauri runtime only. Enables reviewed old 1GB+ personal files to be
# archived to an explicit existing destination on another drive.
SPACEGUARD_ENABLE_LARGE_FILE_ARCHIVE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under the current user's
# .gradle\caches root. Project sources, daemon state, wrapper files, init
# scripts, and lock files remain blocked or skipped.
SPACEGUARD_ENABLE_GRADLE_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under the current user's
# npm-cache\_cacache root. Global packages, project node_modules, and npm index
# metadata remain blocked or skipped.
SPACEGUARD_ENABLE_NPM_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables permanent removal of files already in the
# selected drive's Shell Recycle Bin. Requires the app's permanent-removal
# confirmation and native request acknowledgement.
SPACEGUARD_ENABLE_RECYCLE_BIN_EXECUTOR=0

# Native Tauri runtime only. Enables browser cache cleanup for scanned cache
# roots only. Cookies, sessions, saved logins, extensions, history, and profile
# stores remain blocked by the native target validator.
SPACEGUARD_ENABLE_BROWSER_CACHE_EXECUTOR=0
