# OpenAI advisor. The Tauri desktop command and the Vite dev proxy read
# OPENAI_API_KEY from the process environment or this local .env file. Avoid
# VITE_OPENAI_API_KEY unless you explicitly want to expose a key to the renderer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_REASONING_EFFORT=low

# Native Tauri runtime only. Enables temp cleanup for old files under
# allowlisted Windows temp roots. Keep unset for read-only setup builds.
SPACEGUARD_ENABLE_TEMP_EXECUTOR=0

# Native Tauri runtime only. Keep empty until the seeded temp fixture proof is
# accepted. Real-data route setup and validation stay blocked until this points
# to the accepted first-route completion check JSON.
SPACEGUARD_FIRST_ROUTE_COMPLETION_CHECK=

# Native Tauri runtime only. Enables reviewed node_modules cleanup for selected
# project dependency targets with parent package.json evidence.
SPACEGUARD_ENABLE_PROJECT_DEPS_EXECUTOR=0

# Native Tauri runtime only. Enables reviewed old installer/archive files under
# the current user's Downloads folder to be moved through Recycle Bin semantics.
SPACEGUARD_ENABLE_DOWNLOADS_EXECUTOR=0

# Native Tauri runtime only. Enables reviewed old 1GB+ personal files to be
# archived to an explicit existing destination on another drive.
SPACEGUARD_ENABLE_LARGE_FILE_ARCHIVE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under the current user's
# .gradle\caches root. Project sources, daemon state, wrapper files, init
# scripts, and lock files remain blocked or skipped.
SPACEGUARD_ENABLE_GRADLE_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under the exact current
# user's .cache root. Config, database, lock, log, session, credential,
# project, and identity-like files remain blocked or skipped.
SPACEGUARD_ENABLE_USER_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under scanned Android
# Studio cache roots and the current user's .android\build-cache. AVDs, SDKs,
# emulators, Gradle data, and project folders remain blocked or skipped.
SPACEGUARD_ENABLE_ANDROID_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under scanned current-user
# graphics shader cache roots. Game installs, saves, launcher profiles, configs,
# package folders, and system paths remain blocked or skipped.
SPACEGUARD_ENABLE_SHADER_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under the current user's
# pip\Cache root. Python installs, virtualenvs, site-packages, pip config, and
# package-manager commands remain blocked or skipped.
SPACEGUARD_ENABLE_PIP_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables Docker build-cache cleanup through the
# allowlisted `docker builder prune --force` command after Docker CLI inventory.
# Docker volumes, running containers, images, data-root folders, shell commands,
# and broad system prune remain blocked.
SPACEGUARD_ENABLE_TOOL_NATIVE_PRUNE_EXECUTORS=0

# Native Tauri runtime only. Enables old-file cleanup under the current user's
# npm-cache\_cacache root. Global packages, project node_modules, and npm index
# metadata remain blocked or skipped.
SPACEGUARD_ENABLE_NPM_CACHE_EXECUTOR=0

# Native Tauri runtime only. Enables old-file cleanup under the current user's
# pnpm\store root. Store metadata, global bins, project node_modules, and shell
# commands remain blocked or skipped.
SPACEGUARD_ENABLE_PNPM_STORE_EXECUTOR=0

# Native Tauri runtime only. Enables permanent removal of files already in the
# selected drive's Shell Recycle Bin. Requires the app's permanent-removal
# confirmation and native request acknowledgement.
SPACEGUARD_ENABLE_RECYCLE_BIN_EXECUTOR=0

# Native Tauri runtime only. Enables browser cache cleanup for scanned cache
# roots only. Cookies, sessions, saved logins, extensions, history, and profile
# stores remain blocked by the native target validator.
SPACEGUARD_ENABLE_BROWSER_CACHE_EXECUTOR=0
